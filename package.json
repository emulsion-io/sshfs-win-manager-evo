{
  "name": "sshfs-win-manager-evo",
  "version": "2.2.0",
  "author": "Fabrice Simonet <fabrice@emulsion.io>",
  "contributors": [
    "Evandro Araujo <evandroprogram@gmail.com>"
  ],
  "description": "A GUI for SSHFS-Win (https://github.com/billziss-gh/sshfs-win)",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "npm run build:clean-output && node scripts/run-electron-vite.cjs build && electron-builder",
    "build:dir": "npm run build:clean-output && node scripts/run-electron-vite.cjs build && electron-builder --dir",
    "build:clean": "rimraf out dist/electron dist/web",
    "build:clean-output": "node scripts/clean-build-output.cjs",
    "icons:generate": "node scripts/generate-icons.cjs",
    "dev": "node scripts/run-electron-vite.cjs dev",
    "dev:tray": "node scripts/run-electron-vite.cjs dev -- --systray",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue}\" --fix",
    "postinstall": "npm run lint:fix"
  },
  "build": {
    "productName": "SSHFS-Win Manager Evo",
    "appId": "dev.fabricesimonet.apps.sshfs-win-manager-evo",
    "artifactName": "sshfs-win-manager-evo-setup-v${version}.${ext}",
    "nsis": {
      "oneClick": true,
      "installerIcon": "build/icons/setup-icon.ico",
      "uninstallDisplayName": "SSHFS-Win Manager Evo"
    },
    "directories": {
      "output": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "static",
        "to": "static"
      }
    ],
    "win": {
      "icon": "build/icons/app-icon.ico"
    }
  },
  "dependencies": {
    "uuid": "^14.0.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "less": "^4.4.2",
    "rimraf": "^6.1.3",
    "sass": "^1.94.2",
    "sharp": "^0.35.3",
    "vite": "^7.3.6",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "@babel/runtime": "^7.28.4"
  }
}
